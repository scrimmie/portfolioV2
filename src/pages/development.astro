---
import BrowserWindow from "../components/BrowserWindow.astro";
import RetroTerminal from "../components/RetroTerminal.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Development"
  description="The languages, technologies, and experience behind David D'Apice's full-stack development work."
>
  <div class="flex w-full h-full items-start justify-center flex-col">
    <BrowserWindow url="dev.terminal">
      <RetroTerminal title="DEVELOPMENT PROFILE">
        <div
          class="dev-container flex h-full w-full items-start justify-start overflow-auto"
        >
          <div class="dev-section p-4">
            <div class="command-line">
              <span class="prompt">david@system:~$</span>
              <span class="command">ls languages/</span>
            </div>

            <div class="output-block">
              <ul class="file-list">
                <li>typescript.lang</li>
                <li>javascript.lang</li>
                <li>python.lang</li>
                <li>html.lang</li>
                <li>golang.lang</li>
                <li>css.lang</li>
                <li>java.lang</li>
                <li>c.lang</li>
              </ul>
            </div>

            <div class="command-line">
              <span class="prompt">david@system:~$</span>
              <span class="command">ls technologies/</span>
            </div>

            <div class="output-block">
              <ul class="file-list">
                <li>react.js</li>
                <li>node.js</li>
                <li>next.js</li>
                <li>react-native.js</li>
                <li>ionic.framework</li>
                <li>tailwindcss.css</li>
                <li>material-ui.lib</li>
                <li>vite.build</li>
                <li>fastapi.py</li>
                <li>temporal.workflow</li>
                <li>ai-agents.dev</li>
                <li>express.js</li>
                <li>postgresql.db</li>
                <li>nosql.db</li>
                <li>redis.cache</li>
              </ul>
            </div>

            <div class="command-line">
              <span class="prompt">david@system:~$</span>
              <span class="command">ls experience/</span>
            </div>

            <div class="output-block">
              <ul class="file-list">
                <li>strata-company.corp</li>
                <li>your-money-line.corp</li>
                <li>trava-security.corp</li>
                <li>comcast-corporation.corp</li>
                <li>sig.corp</li>
              </ul>
            </div>
          </div>

          <div class="dev-section p-4">
            <div class="command-line">
              <span class="prompt">david@system:~$</span>
              <span class="command">cat developer.txt</span>
            </div>

            <div class="output-block">
              <pre
                class="developer-text">With eight years of experience as a full-stack developer — these days as a tech lead — I am deeply passionate about bridging the gap between people and technology. I find immense satisfaction in creating seamless user experiences that bring value to individuals. My technical expertise allows me to craft elegant solutions that positively impact the way people interact with technology.

In addition to my technical skills, I am a firm believer in the power of collaboration. Bringing my personality and humor to technology teams is not just about making the workplace more pleasant, but also about fostering creativity and innovation. I am dedicated to not only delivering exceptional products but also ensuring that the process of creating them is enjoyable and rewarding for everyone involved.</pre>
            </div>
          </div>
        </div>
      </RetroTerminal>
    </BrowserWindow>

    <style>
      /* Container queries for responsive layout */
      .dev-container {
        container-type: inline-size;
        flex-direction: row;
        font-family: "JetBrains Mono", monospace;
        color: #00ff00;
        padding: 1rem;
      }

      /* Default: side-by-side layout */
      .dev-section {
        width: 50%;
      }

      /* Terminal Command Lines */
      .command-line {
        margin: 1rem 0 0.5rem 0;
        font-family: "JetBrains Mono", monospace;
      }

      .prompt {
        color: #00aa00;
        text-shadow: 0 0 5px #00aa00;
      }

      .command {
        color: #00ff00;
        text-shadow: 0 0 5px #00ff00;
        margin-left: 0.5rem;
      }

      /* Output blocks */
      .output-block {
        background: rgba(0, 255, 0, 0.05);
        border: 1px solid #004400;
        border-radius: 4px;
        padding: 0.75rem;
        margin: 0.5rem 0 1rem 0;
      }

      /* File listings */
      .file-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.25rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .file-list li {
        color: #00cc00;
        font-size: 0.9rem;
        padding: 0.125rem 0;
      }

      .file-list li::before {
        content: "● ";
        color: #00aa00;
        margin-right: 0.5rem;
      }

      /* Developer text */
      .developer-text {
        color: #00cc00;
        font-size: 0.85rem;
        line-height: 1.5;
        white-space: pre-wrap;
        margin: 0;
      }

      /* When container is small, stack vertically */
      @container (max-width: 768px) {
        .dev-container {
          flex-direction: column;
          padding: 0.75rem;
        }

        .dev-section {
          width: 100%;
        }

        .file-list {
          grid-template-columns: 1fr;
        }

        .command-line {
          font-size: 0.9rem;
        }

        .developer-text {
          font-size: 0.8rem;
        }
      }

      @container (max-width: 480px) {
        .dev-container {
          padding: 0.5rem;
        }

        .command-line {
          font-size: 0.8rem;
        }

        .developer-text {
          font-size: 0.75rem;
        }

        .output-block {
          padding: 0.5rem;
        }
      }
    </style>
  </div>
</Layout>
