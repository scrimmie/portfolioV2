---
import BrowserWindow from "../components/BrowserWindow.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact - David D'Apice">
  <BrowserWindow url="mail.dapice.dev/inbox">
    <div class="flex h-full bg-gray-50">
      <!-- Sidebar -->
      <div class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <!-- Profile Section -->
        <div class="p-4 border-b border-gray-200">
          <div class="flex items-center space-x-3">
            <div
              class="w-10 h-10 bg-gray-600 rounded-full flex items-center justify-center text-white font-semibold"
            >
              Y
            </div>
            <div>
              <div class="font-medium text-gray-900">You</div>
              <div class="text-sm text-gray-500">you@you.com</div>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <div class="flex-1 p-2">
          <nav class="space-y-1">
            <div
              class="bg-blue-50 text-blue-700 group flex items-center px-3 py-2 text-sm font-medium rounded-md"
            >
              <svg
                class="text-blue-500 mr-3 h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-4m-4 0H9m11 0a2 2 0 01-2 2H6a2 2 0 01-2-2 11 0z"
                ></path>
              </svg>
              Inbox
              <span
                class="ml-auto bg-blue-100 text-blue-600 text-xs rounded-full px-2 py-1"
                >1</span
              >
            </div>
            <div
              class="text-gray-400 cursor-not-allowed flex items-center px-3 py-2 text-sm font-medium rounded-md"
            >
              <svg
                class="text-gray-300 mr-3 h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              Sent
            </div>
            <div
              class="text-gray-400 cursor-not-allowed flex items-center px-3 py-2 text-sm font-medium rounded-md"
            >
              <svg
                class="text-gray-300 mr-3 h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
              Drafts
            </div>
          </nav>
        </div>

        <!-- Social Links -->
        <div class="p-4 border-t border-gray-200">
          <h3
            class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3"
          >
            Connect with David
          </h3>
          <div class="space-y-2">
            <a
              href="https://instagram.com/iamdrdigital"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center text-sm text-gray-600 hover:text-pink-600 transition-colors group"
            >
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                ></path>
              </svg>
              <span class="group-hover:underline">Instagram</span>
              <svg
                class="w-3 h-3 ml-1 opacity-0 group-hover:opacity-100 transition-opacity"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                ></path>
              </svg>
            </a>

            <a
              href="https://github.com/scrimmie"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors group"
            >
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              <span class="group-hover:underline">GitHub</span>
              <svg
                class="w-3 h-3 ml-1 opacity-0 group-hover:opacity-100 transition-opacity"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                ></path>
              </svg>
            </a>

            <a
              href="https://linkedin.com/in/david-dapice"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center text-sm text-gray-600 hover:text-blue-600 transition-colors group"
            >
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              <span class="group-hover:underline">LinkedIn</span>
              <svg
                class="w-3 h-3 ml-1 opacity-0 group-hover:opacity-100 transition-opacity"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Main Email Content -->
      <div class="flex-1 flex flex-col">
        <!-- Email Header -->
        <div class="bg-white border-b border-gray-200 px-6 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
              </button>
              <h1 class="text-lg font-semibold text-gray-900">
                Let's Connect!
              </h1>
            </div>
            <div class="flex items-center space-x-2">
              <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V9a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
                  ></path>
                </svg>
              </button>
              <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"
                  ></path>
                </svg>
              </button>
              <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                  ></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Email Meta -->
        <div class="bg-white border-b border-gray-200 px-6 py-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div
                class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white font-semibold text-sm"
              >
                DD
              </div>
              <div>
                <div class="font-medium text-gray-900">David D'Apice</div>
                <div class="text-sm text-gray-500">to you</div>
              </div>
            </div>
            <div class="text-sm text-gray-500">Just now</div>
          </div>
        </div>

        <!-- Email Body -->
        <div class="flex-1 bg-white px-6 py-6 overflow-auto">
          <div class="max-w-3xl">
            <div class="prose prose-gray max-w-none">
              <p class="text-gray-700 mb-4">Hey there! 👋</p>

              <p class="text-gray-700 mb-4">
                I hope this email finds you well! I wanted to reach out because
                I'm always excited to connect with fellow creators, developers,
                and innovators who are passionate about building amazing things.
              </p>

              <p class="text-gray-700 mb-6">
                Whether you're interested in collaborating on a project,
                discussing new ideas, sharing photography tips, or just having a
                good conversation about technology and creativity, I'd love to
                hear from you.
              </p>

              <!-- Contact Info Box -->
              <div
                class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6"
              >
                <h3 class="text-lg font-semibold text-blue-900 mb-4">
                  Ready to connect? Here's how:
                </h3>
                <div class="space-y-3">
                  <div class="flex items-center">
                    <svg
                      class="w-5 h-5 text-blue-600 mr-3"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                      ></path>
                    </svg>
                    <span class="text-blue-900 font-medium">Email:</span>
                    <a
                      href="mailto:david@dapice.dev"
                      class="ml-2 text-blue-600 hover:text-blue-800 underline"
                      >david@dapice.dev</a
                    >
                  </div>
                  <div class="flex items-center">
                    <svg
                      class="w-5 h-5 text-blue-600 mr-3"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                      ></path>
                    </svg>
                    <span class="text-blue-900 font-medium">LinkedIn:</span>
                    <a
                      href="https://linkedin.com/in/david-dapice"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="ml-2 text-blue-600 hover:text-blue-800 underline"
                      >linkedin.com/in/david-dapice</a
                    >
                  </div>
                  <div class="flex items-center">
                    <svg
                      class="w-5 h-5 text-blue-600 mr-3"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                      ></path>
                    </svg>
                    <span class="text-blue-900 font-medium">GitHub:</span>
                    <a
                      href="https://github.com/scrimmie"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="ml-2 text-blue-600 hover:text-blue-800 underline"
                      >github.com/scrimmie</a
                    >
                  </div>
                </div>
              </div>

              <p class="text-gray-700 mb-4">
                I'm particularly passionate about:
              </p>

              <ul class="text-gray-700 mb-6 list-disc list-inside space-y-1">
                <li>Full-stack development and modern web technologies</li>
                <li>Photography and visual storytelling</li>
                <li>Creative projects that blend technology and art</li>
                <li>Building meaningful connections in the tech community</li>
              </ul>

              <p class="text-gray-700 mb-6">
                Don't hesitate to reach out - I'd love to learn about what
                you're working on and explore how we might collaborate or simply
                share ideas!
              </p>

              <p class="text-gray-700 mb-2">Looking forward to connecting,</p>
              <p class="text-gray-900 font-medium">David D'Apice</p>
              <p class="text-sm text-gray-500">
                Full-Stack Developer & Creative
              </p>
            </div>
          </div>
        </div>

        <!-- Quick Reply Actions -->
        <div class="bg-gray-50 border-t border-gray-200 px-6 py-4">
          <div class="flex items-center space-x-3">
            <a
              href="mailto:david@dapice.dev?subject=Let's connect!"
              class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors flex items-center"
            >
              <svg
                class="w-4 h-4 mr-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
              </svg>
              Reply
            </a>
            <button
              disabled
              class="text-gray-400 cursor-not-allowed px-4 py-2 rounded-lg font-medium flex items-center"
            >
              <svg
                class="w-4 h-4 mr-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V9a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
                ></path>
              </svg>
              Forward
            </button>
            <button
              disabled
              class="text-gray-400 cursor-not-allowed px-4 py-2 rounded-lg font-medium flex items-center"
            >
              <svg
                class="w-4 h-4 mr-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
              </svg>
              Save
            </button>
          </div>
        </div>
      </div>
    </div>
  </BrowserWindow>
</Layout>

<link
  href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&display=swap"
  rel="stylesheet"
/>
