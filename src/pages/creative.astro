---
import BrowserWindow from "../components/BrowserWindow.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import backgroundImage from "../assets/backgrounds/dj-background.jpg";
import logo from "../assets/DrDigitalLogo.gif";
import Player from "../components/Player";
import Logo from "../components/Logo";
import SocialLink from "../components/SocialLink.astro";
---

<Layout
  title="Creative"
  description="DrDigital - the creative side of David D'Apice: music, DJing, game dev, gaming, and photography."
>
  <div class="w-full h-full">
    <BrowserWindow url="drdigital.nexus">
      <div class="relative w-full min-h-full overflow-auto bg-black">
        <!-- Enhanced background with cyberpunk effects -->
        <div class="absolute inset-0 z-0">
          <Image
            class="absolute inset-0 w-full h-full object-cover"
            src={backgroundImage}
            alt="cyberpunk dj background"
          />
          <!-- Dark overlay with cyberpunk colors -->
          <div
            class="absolute inset-0 bg-gradient-to-br from-black/80 via-purple-900/60 to-black/80"
          >
          </div>
          <!-- Grid overlay -->
          <div
            class="absolute inset-0 bg-[linear-gradient(90deg,rgba(0,255,255,0.03)_1px,transparent_1px),linear-gradient(rgba(0,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"
          >
          </div>
        </div>

        <!-- Main content container - 3 stacked cards -->
        <div class="relative z-10 w-full max-w-4xl mx-auto p-4 space-y-4">
          <!-- 1. Logo Card -->
          <div class="h-40 md:h-48 lg:h-56">
            <div
              class="w-full h-full bg-black/40 backdrop-blur-sm border border-cyan-400/30 rounded-lg p-4"
            >
              <Logo
                logoSrc={logo.src}
                alt="DrDigital Cyberpunk Logo"
                client:load
              />
            </div>
          </div>

          <!-- 2. Player Card -->
          <div class="h-48 md:h-56 lg:h-64">
            <div
              class="w-full h-full bg-black/40 backdrop-blur-sm border border-cyan-400/30 rounded-lg overflow-hidden"
            >
              <Player client:load />
            </div>
          </div>

          <!-- 3. Description Card - Auto height for content -->
          <div class="w-full">
            <div
              class="w-full bg-black/60 backdrop-blur-sm border border-cyan-400/30 rounded-lg p-6 lg:p-8"
            >
              <!-- Terminal-style header -->
              <div
                class="flex items-center mb-6 text-cyan-400 font-JetbrainsMono text-sm"
              >
                <span class="w-3 h-3 bg-red-500 rounded-full mr-2 animate-pulse"
                ></span>
                <span
                  class="w-3 h-3 bg-yellow-500 rounded-full mr-2 animate-pulse"
                  style="animation-delay: 0.2s"></span>
                <span
                  class="w-3 h-3 bg-green-500 rounded-full mr-4 animate-pulse"
                  style="animation-delay: 0.4s"></span>
                <span class="opacity-80">drdigital@nexus:~/creative$</span>
                <span class="ml-2 animate-pulse">_</span>
              </div>

              <!-- Cyberpunk-styled text content -->
              <div class="space-y-6">
                <div
                  class="text-cyan-400 font-JetbrainsMono text-lg md:text-xl font-bold mb-6 tracking-wider"
                >
                  > CREATIVE_MATRIX.EXE
                </div>

                <div
                  class="text-white font-JetbrainsMono text-sm md:text-base leading-relaxed space-y-6"
                >
                  <p class="border-l-4 border-cyan-400 pl-4 bg-cyan-400/5 py-3">
                    <span class="text-cyan-400 font-bold">[OFF THE CLOCK]</span
                    ><br />
                    This is DrDigital, the stuff I make and mess with when I'm not
                    in a pull request. None of it's work, but it all comes from
                    the same curiosity.
                  </p>

                  <p
                    class="border-l-4 border-purple-400 pl-4 bg-purple-400/5 py-3"
                  >
                    <span class="text-purple-400 font-bold">[MUSIC]</span><br />
                    I DJ with friends, nothing serious, usually just in
                    someone's living room. Mostly it's an excuse to share music,
                    which I'm pretty obsessive about. I'm always digging up new
                    stuff to play.
                  </p>

                  <p class="border-l-4 border-pink-400 pl-4 bg-pink-400/5 py-3">
                    <span class="text-pink-400 font-bold">[GAMES]</span><br />
                    I build small games to see how they work (most never get
                    finished), and I play plenty of them too. It's where I go to
                    turn my brain off after a day staring at code.
                  </p>

                  <p
                    class="border-l-4 border-green-400 pl-4 bg-green-400/5 py-3"
                  >
                    <span class="text-green-400 font-bold">[PHOTOGRAPHY]</span
                    ><br />
                    A camera's how I slow down. Code rewards speed, this one
                    rewards patience, and I like having both.
                  </p>

                  <div
                    class="mt-8 p-6 bg-gradient-to-r from-cyan-500/10 to-purple-500/10 border border-cyan-400/30 rounded-lg"
                  >
                    <p class="text-cyan-300 italic text-center text-base">
                      &gt; same brain, different output.
                    </p>
                  </div>
                </div>
              </div>

              <!-- Social Links Section -->
              <div class="mt-10">
                <div
                  class="text-cyan-400 font-JetbrainsMono text-sm mb-6 tracking-wider"
                >
                  > SOCIAL_NETWORK_INTERFACES
                </div>
                <div class="flex justify-center gap-8 md:gap-12">
                  <SocialLink
                    platform="Instagram"
                    link="https://www.instagram.com/iamdrdigital/"
                    index={0}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="1em"
                      height="1em"
                      viewBox="0 0 24 24"
                      class="w-full h-full"
                    >
                      <g fill="none" stroke="currentColor" stroke-width="1.5">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M12 16a4 4 0 1 0 0-8a4 4 0 0 0 0 8"></path>
                        <path
                          d="M3 16V8a5 5 0 0 1 5-5h8a5 5 0 0 1 5 5v8a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5Z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="m17.5 6.51l.01-.011"></path>
                      </g>
                    </svg>
                  </SocialLink>
                </div>
              </div>

              <!-- Bottom spacing -->
              <div class="mt-8"></div>
            </div>
          </div>

          <!-- Bottom spacing for scroll -->
          <div class="h-8"></div>
        </div>

        <!-- Floating UI elements -->
        <div
          class="absolute top-4 right-4 z-20 flex items-center space-x-2 text-cyan-400 font-JetbrainsMono text-xs"
        >
          <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
          <span>SYSTEM_ONLINE</span>
        </div>

        <div
          class="absolute bottom-4 left-4 z-20 text-cyan-400 font-JetbrainsMono text-xs opacity-60"
        >
          <span>NEXUS_v2.2047</span>
        </div>

        <!-- Animated corner brackets -->
        <div
          class="absolute top-0 left-0 w-8 h-8 border-l-2 border-t-2 border-cyan-400/50 z-20"
        >
        </div>
        <div
          class="absolute top-0 right-0 w-8 h-8 border-r-2 border-t-2 border-cyan-400/50 z-20"
        >
        </div>
        <div
          class="absolute bottom-0 left-0 w-8 h-8 border-l-2 border-b-2 border-cyan-400/50 z-20"
        >
        </div>
        <div
          class="absolute bottom-0 right-0 w-8 h-8 border-r-2 border-b-2 border-cyan-400/50 z-20"
        >
        </div>
      </div>
    </BrowserWindow>
  </div>
</Layout>
