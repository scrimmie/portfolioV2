---
import { Navigation } from "../components/Navigation";
import { MacTopBar } from "../components/MacTopBar";
interface Props {
  title: string;
}
import { ViewTransitions } from "astro:transitions";
import image from "../assets/backgrounds/background.jpg";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description?: string;
}

const SITE_NAME = "David D'Apice";
const {
  title,
  description = "David D'Apice — Full-Stack Developer, Photographer & Creative.",
} = Astro.props;
// Give every page a unique, descriptive <title> without double-printing the name.
const pageTitle = title.includes(SITE_NAME)
  ? title
  : `${title} — ${SITE_NAME}`;
---

<!doctype html>
<html lang="en" class="overflow-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / social previews -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.src} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.src} />

    <ViewTransitions />
    <title>{pageTitle}</title>
  </head>
  <body class="overflow-hidden">
    <!-- Mac-style top bar -->
    <MacTopBar client:load />

    <main class="flex w-screen h-screen overflow-hidden">
      <Image
        src={image}
        alt="background image"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Adjust content area to account for top bar (h-6) and bottom nav (h-16) -->
      <div class="z-10 w-full h-full overflow-auto pb-16 pt-6">
        <slot />
      </div>
      <footer
        class="z-20 fixed bottom-0 left-0 flex h-16 w-full items-center justify-center px-4 text-gray-700"
      >
        <Navigation client:load />
      </footer>
    </main>
  </body>
</html>
<style>
  @font-face {
    font-family: "JetBrainsMono";
    src: url("/fonts/JetBrainsMono-Regular.woff2") format("woff2");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  html,
  body {
    position: fixed;
    width: 100%;
    height: 100%;
    overscroll-behavior: none;
  }

  :global(.overflow-auto) {
    scrollbar-width: thin;
    -ms-overflow-style: none;
    overflow-y: auto;
    overflow-x: hidden;
  }

  :global(.overflow-auto::-webkit-scrollbar) {
    width: 6px;
  }

  :global(.overflow-auto::-webkit-scrollbar-thumb) {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 3px;
  }
</style>
