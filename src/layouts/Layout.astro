---
import { Navigation } from "../components/Navigation";
interface Props {
  title: string;
}
import { ViewTransitions } from "astro:transitions";
import image from "../assets/backgrounds/background.jpg";
import { Image } from "astro:assets";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="overflow-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="David D'Apice Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <title>{title}</title>
  </head>
  <body class="overflow-hidden">
    <main class="flex w-screen h-screen overflow-hidden">
      <Image
        src={image}
        alt="background image"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="z-10 w-full h-full overflow-auto pb-16">
        <slot />
      </div>
      <footer
        class="z-20 fixed bottom-0 left-0 flex h-16 w-full items-center justify-center px-4 text-gray-700"
      >
        <Navigation client:load />
      </footer>
    </main>
  </body>
</html>
<style>
  @font-face {
    font-family: "JetBrainsMono";
    src: url("/fonts/JetBrainsMono-Regular.woff2") format("woff2");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  html,
  body {
    position: fixed;
    width: 100%;
    height: 100%;
    overscroll-behavior: none;
  }

  :global(.overflow-auto) {
    scrollbar-width: thin;
    -ms-overflow-style: none;
    overflow-y: auto;
    overflow-x: hidden;
  }

  :global(.overflow-auto::-webkit-scrollbar) {
    width: 6px;
  }

  :global(.overflow-auto::-webkit-scrollbar-thumb) {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 3px;
  }
</style>
