---
import BrowserWindow from "../components/BrowserWindow.astro";
import RetroTerminal from "../components/RetroTerminal.astro";
import Layout from "./Layout.astro";
import { SlickSlider } from "../components/SlickSlider";
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <div class="flex w-full h-full items-start justify-center flex-col">
    <BrowserWindow url={`projects/${frontmatter.title}.terminal`}>
      <RetroTerminal title={`PROJECT: ${frontmatter.title.toUpperCase()}`}>
        <div
          class="project-container overflow-auto w-full h-max flex justify-center items-center flex-col"
        >
          <!-- Terminal Output Header -->
          <div class="terminal-output">
            <div class="command-line">
              <span class="prompt">user@system:~$</span>
              <span class="command">cat project_info.txt</span>
            </div>

            <div class="output-block">
              <div class="ascii-header">
                <pre class="ascii-art">{frontmatter.title.toUpperCase()}</pre>
              </div>

              <dl class="project-details">
                <div class="detail-line">
                  <dt class="label">DATE:</dt>
                  <dd class="value">
                    {
                      frontmatter.projectDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                        timeZone: "UTC",
                      })
                    }
                  </dd>
                </div>
                <div class="detail-line">
                  <dt class="label">DESC:</dt>
                  <dd class="value">{frontmatter.description}</dd>
                </div>
                {
                  frontmatter.projectLink && (
                    <div class="detail-line">
                      <dt class="label">LINK:</dt>
                      <dd class="value">
                        <a
                          href={frontmatter.projectLink}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="project-url"
                        >
                          {frontmatter.projectLink}
                        </a>
                      </dd>
                    </div>
                  )
                }
              </dl>
            </div>
          </div>

          <!-- Gallery Command -->
          <div class="command-line">
            <span class="prompt">user@system:~$</span>
            <span class="command">display screenshots/</span>
          </div>

          <div class="gallery-section">
            <SlickSlider
              images={frontmatter.images.map((item: any) => {
                return item.src;
              })}
              alt={`${frontmatter.title} screenshot`}
              client:only="react"
            />
          </div>

          <!-- Documentation Command -->
          <div class="command-line">
            <span class="prompt">user@system:~$</span>
            <span class="command">cat documentation.md</span>
          </div>

          <article class="content-article">
            <slot />
          </article>
        </div>
      </RetroTerminal>
    </BrowserWindow>
  </div>

  <style is:global>
    /* Container queries */
    .project-container {
      container-type: inline-size;
      padding: 1rem;
      font-family: "JetBrains Mono", monospace;
      color: #00ff00;
      line-height: 1.4;
    }

    /* Terminal Command Lines */
    .command-line {
      margin: 1.5rem 0 0.5rem 0;
      font-family: "JetBrains Mono", monospace;
      text-align: left;
      width: 100%;
    }

    .prompt {
      color: #00aa00;
      text-shadow: 0 0 5px #00aa00;
    }

    .command {
      color: #00ff00;
      text-shadow: 0 0 5px #00ff00;
      margin-left: 0.5rem;
    }

    /* Terminal Output Blocks */
    .terminal-output {
      margin: 2rem 0;
      width: 100%;
      text-align: left;
    }

    .output-block {
      background: rgba(0, 255, 0, 0.05);
      border: 1px solid #004400;
      border-radius: 4px;
      padding: 1rem;
      margin-top: 0.5rem;
    }

    .ascii-header {
      border-bottom: 1px solid #004400;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
    }

    .ascii-art {
      color: #00ff00;
      text-shadow: 0 0 10px #00ff00;
      font-size: 1.5rem;
      font-weight: bold;
      text-align: center;
      margin: 0;
      letter-spacing: 0.1em;
    }

    .project-details {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .detail-line {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .label {
      color: #00aa00;
      font-weight: bold;
      min-width: 60px;
      margin: 0;
    }

    .value {
      color: #00ff00;
      margin: 0;
      overflow-wrap: anywhere;
    }

    .project-url {
      color: #00ccff;
      text-decoration: underline;
      cursor: pointer;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .project-url:hover {
      color: #00ffff;
      text-shadow: 0 0 5px #00ccff;
    }

    /* Gallery Section */
    .gallery-section {
      width: 100%;
      max-width: 1200px;
      margin: 1rem auto 2rem auto;
      border: 1px solid #004400;
      border-radius: 4px;
      padding: 1rem;
      background: rgba(0, 255, 0, 0.02);
    }

    /* Responsive gallery width limits */
    @container (max-width: 1400px) {
      .gallery-section {
        max-width: 1000px;
      }
    }

    @container (max-width: 1200px) {
      .gallery-section {
        max-width: 800px;
      }
    }

    @container (max-width: 900px) {
      .gallery-section {
        max-width: 600px;
      }
    }

    /* Content Article */
    .content-article {
      width: 100%;
      margin: 1rem 0;
      background: rgba(0, 255, 0, 0.05);
      border: 1px solid #004400;
      border-radius: 4px;
      padding: 1rem;
      text-align: left;
    }

    /* Container Query Responsive Design */
    @container (max-width: 768px) {
      .project-container {
        padding: 0.75rem;
      }

      .ascii-art {
        font-size: 1.2rem;
      }

      .command-line {
        font-size: 0.9rem;
      }

      .detail-line {
        flex-direction: column;
        gap: 0.25rem;
      }
    }

    @container (max-width: 480px) {
      .project-container {
        padding: 0.5rem;
      }

      .ascii-art {
        font-size: 1rem;
      }

      .command-line,
      .prompt,
      .command {
        font-size: 0.8rem;
      }

      .output-block {
        padding: 0.75rem;
      }
    }

    /* Article Typography - Retro Terminal Style */
    article {
      font-family: "JetBrains Mono", monospace;
      line-height: 1.6;
      color: #00ff00;
    }

    /* Headers with terminal styling */
    article h1 {
      font-size: 1.5rem;
      font-weight: bold;
      margin-bottom: 1rem;
      color: #00ff00;
      text-shadow: 0 0 10px #00ff00;
      text-transform: uppercase;
      border-bottom: 2px solid #004400;
      padding-bottom: 0.5rem;
    }

    article h2 {
      font-size: 1.25rem;
      font-weight: bold;
      margin-bottom: 0.75rem;
      color: #00aa00;
      text-shadow: 0 0 5px #00aa00;
      text-transform: uppercase;
    }

    article h3 {
      font-size: 1.1rem;
      font-weight: bold;
      margin-bottom: 0.5rem;
      color: #00ff00;
    }

    article h4,
    article h5,
    article h6 {
      font-size: 1rem;
      font-weight: bold;
      margin-bottom: 0.5rem;
      color: #00aa00;
    }

    /* Content styling */
    article p {
      margin-bottom: 1rem;
      color: #00cc00;
      font-size: 0.9rem;
    }

    article a {
      color: #00ccff;
      text-decoration: underline;
      transition: all 0.2s;
    }

    article a:hover {
      color: #00ffff;
      text-shadow: 0 0 5px #00ccff;
    }

    article strong {
      font-weight: bold;
      color: #00ff00;
      text-shadow: 0 0 5px #00ff00;
    }

    article em {
      font-style: italic;
      color: #00aa00;
    }

    /* Lists */
    article ul,
    article ol {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }

    article li {
      margin-bottom: 0.25rem;
      color: #00cc00;
    }

    article ul li::marker {
      color: #00aa00;
    }

    article ol li::marker {
      color: #00aa00;
    }

    /* Code blocks */
    article pre {
      background: rgba(0, 50, 0, 0.3);
      border: 1px solid #004400;
      border-radius: 4px;
      padding: 1rem;
      margin: 1rem 0;
      overflow-x: auto;
    }

    article code {
      background: rgba(0, 50, 0, 0.2);
      border: 1px solid #004400;
      border-radius: 2px;
      padding: 0.125rem 0.375rem;
      font-size: 0.85rem;
      color: #00ffaa;
    }

    article pre code {
      background: none;
      border: none;
      padding: 0;
      color: #00ff00;
    }

    /* Blockquotes */
    article blockquote {
      border-left: 4px solid #004400;
      padding: 1rem;
      margin: 1rem 0;
      font-style: italic;
      color: #00aa00;
      background: rgba(0, 255, 0, 0.05);
      border-radius: 4px;
    }

    /* Tables */
    article table {
      width: 100%;
      border-collapse: collapse;
      margin: 1rem 0;
      background: rgba(0, 255, 0, 0.05);
      border: 1px solid #004400;
      border-radius: 4px;
      overflow: hidden;
    }

    article th {
      background: rgba(0, 50, 0, 0.3);
      padding: 0.75rem;
      text-align: left;
      font-weight: bold;
      color: #00ff00;
      border-bottom: 1px solid #004400;
    }

    article td {
      padding: 0.75rem;
      border-bottom: 1px solid #004400;
      color: #00cc00;
    }

    /* Images */
    article img {
      width: 100%;
      border: 2px solid #004400;
      border-radius: 4px;
      margin: 1rem 0;
      filter: hue-rotate(90deg) saturate(1.2);
    }

    /* Responsive typography adjustments */
    @container (max-width: 768px) {
      article h1 {
        font-size: 1.25rem;
      }

      article h2 {
        font-size: 1.1rem;
      }

      article h3 {
        font-size: 1rem;
      }

      article p {
        font-size: 0.85rem;
      }

      article code {
        font-size: 0.8rem;
      }
    }

    @container (max-width: 480px) {
      article h1 {
        font-size: 1.1rem;
      }

      article h2 {
        font-size: 1rem;
      }

      article h3 {
        font-size: 0.95rem;
      }

      article p {
        font-size: 0.8rem;
      }

      article code {
        font-size: 0.75rem;
      }
    }
  </style>
</Layout>
