---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;

// Sort once and reuse for both marquee copies so the loop stays in order.
const sortedProjects = [...projects].sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
);

// The track holds two copies of the list; the column count must be 2x the
// project count so the marquee loops seamlessly for any number of projects.
const columnCount = sortedProjects.length * 2;
---

<div class="flex w-full h-full items-center justify-center">
  <div class="flex h-full items-center">
    <div class="h-full relative overflow-hidden">
      <div class="w-full h-full animate-marquee">
        <div
          class="m-auto grid h-full w-[400%] place-items-center"
          style={`grid-template-columns: repeat(${columnCount}, minmax(0, 1fr));`}
        >
          {
            [...sortedProjects, ...sortedProjects].map((project) => (
              <a
                class="h-full w-full flex justify-center items-center px-10 hover:scale-[1.05] hover:shadow-xl"
                href={"/projects/" + project.slug}
              >
                <Image
                  class="h-fit w-fit object-cover"
                  src={project.data.logoImage}
                  alt={project.data.title}
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>
